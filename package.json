{
  "name": "testmu-sdet1-chirag",
  "version": "1.0.0",
  "description": "SDET-1 AI-Native Quality Engineering Challenge — TestMu AI Assessment",
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:login": "npx playwright test tests/login/",
    "test:dashboard": "npx playwright test tests/dashboard/",
    "test:api": "npx playwright test tests/api/",
    "test:report": "npx playwright show-report reports",
    "test:headed": "npx playwright test --headed",
    "analyze": "node scripts/analyze-failures.js",
    "test:ai": "npm test && npm run analyze",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:allure": "npx playwright test; npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "dotenv": "^16.6.1",
    "openai": "^4.28.0"
  }
}
